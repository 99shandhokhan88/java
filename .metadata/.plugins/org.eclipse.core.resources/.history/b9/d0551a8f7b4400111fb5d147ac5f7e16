package sys.main;

public class Main {

	public static void main(String[] args) {
		
		/*
		 * L'API String può essere usata in due vesti differenti:
		 * 
		 * 1. literal
		 * 2. Object
		 */
		
		// literal
		String s1 = "hello";
		
		String s2 = "hello";
		
		// classic Object
		String s3 = new String("hello");
		
		String s4 = new String("hello");
		
		
		System.out.println(s1==s2);
		System.out.println(s3==s4);
		
		

	}

}
